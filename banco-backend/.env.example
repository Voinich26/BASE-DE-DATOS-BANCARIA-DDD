# ══════════════════════════════════════════════════════════════════════════════
# Banco DDD Backend — Variables de entorno
# Copiar a .env y ajustar valores. NUNCA commitear .env al repositorio.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/banco_ddd?useSSL=false&serverTimezone=America/Bogota&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=

# ── JWT — SEGURIDAD CRÍTICA ───────────────────────────────────────────────────
# PRODUCCIÓN: generar con: openssl rand -base64 64
# El secret debe tener al menos 256 bits (32 bytes) para HMAC-SHA256
JWT_SECRET=BancoDDD2026SecretKeyMustBe256BitsLongForHS256Algorithm!!
# Access token: 24 horas (86400000 ms)
JWT_EXPIRATION_MS=86400000
# Refresh token: 7 días (604800000 ms)
JWT_REFRESH_MS=604800000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Máximo de solicitudes por IP en ventana de 60 segundos
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REFRESH=20

# ── Servidor ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
APP_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin espacios)
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ── Docker MySQL ──────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
